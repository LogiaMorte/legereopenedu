---
import Layout from '../layouts/Layout.astro';
import { useTranslations } from '../i18n/utils';
const lang = 'tr' as const;
const t = useTranslations(lang);
---

<Layout lang={lang} pageTitle="Profilim">
  <div class="relative min-h-screen pt-24 pb-16 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto">
      <a href="/" class="inline-flex items-center gap-2 text-gold-500 hover:text-gold-300 transition-colors font-heading text-sm mb-8 group">
        <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
        </svg>
        {t('login.back')}
      </a>

      <!-- Not Logged In State -->
      <div id="profile-not-logged-in" class="hidden">
        <div class="glass gold-glow rounded-2xl p-8 text-center max-w-md mx-auto">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-gold-500/10 border border-gold-500/20 mb-4">
            <svg class="w-8 h-8 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
            </svg>
          </div>
          <h1 class="text-xl font-heading font-bold text-text-primary mb-2">{t('profile.notLoggedIn')}</h1>
          <a href="/login" class="btn-gold justify-center text-sm py-3 mt-4 inline-flex">
            {t('profile.goLogin')}
          </a>
        </div>
      </div>

      <!-- Loading State -->
      <div id="profile-loading" class="text-center py-20">
        <div class="inline-flex items-center gap-3 text-text-secondary font-heading text-sm">
          <svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
          </svg>
          Yükleniyor...
        </div>
      </div>

      <!-- Profile Content -->
      <div id="profile-content" class="hidden space-y-6">

        <!-- User Info Card -->
        <div class="glass gold-glow rounded-2xl p-6 sm:p-8">
          <div class="flex flex-col sm:flex-row sm:items-start gap-6">
            <div class="shrink-0">
              <div class="w-20 h-20 rounded-full bg-gold-500/10 border-2 border-gold-500/30 flex items-center justify-center">
                <span id="profile-avatar" class="text-3xl font-heading font-bold text-gold-500"></span>
              </div>
            </div>
            <div class="flex-1 min-w-0">
              <h1 id="profile-name" class="text-2xl font-heading font-bold text-text-primary mb-1"></h1>
              <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-text-secondary mb-4">
                <span id="profile-university" class="flex items-center gap-1.5">
                  <svg class="w-4 h-4 text-gold-500/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342" />
                  </svg>
                  <span id="profile-uni-text"></span>
                </span>
                <span id="profile-department" class="flex items-center gap-1.5">
                  <svg class="w-4 h-4 text-gold-500/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 0 0 3 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 0 0 5.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 0 0 9.568 3Z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6Z" />
                  </svg>
                  <span id="profile-dept-text"></span>
                </span>
                <span id="profile-joindate" class="flex items-center gap-1.5">
                  <svg class="w-4 h-4 text-gold-500/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
                  </svg>
                  <span>{t('profile.joinDate')}:</span>
                  <span id="profile-join-text"></span>
                </span>
              </div>
              <!-- School Email (if exists) -->
              <span id="profile-school-email" class="hidden flex items-center gap-1.5">
                <svg class="w-4 h-4 text-gold-500/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
                </svg>
                <span id="profile-school-email-text"></span>
              </span>
              <!-- Privacy Toggles -->
              <div class="flex flex-wrap gap-4">
                <label class="flex items-center gap-2 text-xs text-text-secondary cursor-pointer group">
                  <input type="checkbox" id="toggle-fullname" class="w-4 h-4 rounded bg-white/5 border-white/20 text-gold-500 focus:ring-gold-500/25 focus:ring-offset-0 accent-[#D4A843]" />
                  <span class="group-hover:text-text-primary transition-colors">{t('profile.showFullName')}</span>
                </label>
                <label class="flex items-center gap-2 text-xs text-text-secondary cursor-pointer group">
                  <input type="checkbox" id="toggle-email" class="w-4 h-4 rounded bg-white/5 border-white/20 text-gold-500 focus:ring-gold-500/25 focus:ring-offset-0 accent-[#D4A843]" />
                  <span class="group-hover:text-text-primary transition-colors">{t('profile.showEmail')}</span>
                </label>
              </div>
            </div>
          </div>
        </div>

        <!-- Stats Row -->
        <div class="grid grid-cols-3 gap-4">
          <div class="glass rounded-xl p-4 text-center">
            <div id="stat-workshops" class="text-2xl font-heading font-bold text-gold-500">0</div>
            <div class="text-xs text-text-secondary font-heading mt-1">{t('profile.workshops')}</div>
          </div>
          <div class="glass rounded-xl p-4 text-center">
            <div id="stat-certificates" class="text-2xl font-heading font-bold text-gold-500">0</div>
            <div class="text-xs text-text-secondary font-heading mt-1">{t('profile.certificates')}</div>
          </div>
          <div class="glass rounded-xl p-4 text-center">
            <div id="stat-badges" class="text-2xl font-heading font-bold text-gold-500">0</div>
            <div class="text-xs text-text-secondary font-heading mt-1">{t('profile.badges')}</div>
          </div>
        </div>

        <!-- Edit Profile Section -->
        <div class="glass rounded-2xl p-6 sm:p-8">
          <button id="edit-toggle" class="w-full flex items-center justify-between text-lg font-heading font-bold text-text-primary">
            <span class="flex items-center gap-2">
              <svg class="w-5 h-5 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
              </svg>
              Profili Düzenle
            </span>
            <svg id="edit-chevron" class="w-5 h-5 text-text-secondary transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
            </svg>
          </button>
          <div id="edit-form-container" class="hidden mt-6 space-y-4">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-text-secondary text-xs font-heading font-medium mb-1.5">Üniversite</label>
                <input type="text" id="edit-university" class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-text-primary text-sm font-body placeholder:text-text-secondary/40 focus:border-gold-500/50 focus:outline-none focus:ring-1 focus:ring-gold-500/25 transition-colors" />
              </div>
              <div>
                <label class="block text-text-secondary text-xs font-heading font-medium mb-1.5">Bölüm</label>
                <input type="text" id="edit-department" class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-text-primary text-sm font-body placeholder:text-text-secondary/40 focus:border-gold-500/50 focus:outline-none focus:ring-1 focus:ring-gold-500/25 transition-colors" />
              </div>
            </div>
            <div>
              <label class="block text-text-secondary text-xs font-heading font-medium mb-1.5">Okul E-postası</label>
              <input type="email" id="edit-school-email" class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-text-primary text-sm font-body placeholder:text-text-secondary/40 focus:border-gold-500/50 focus:outline-none focus:ring-1 focus:ring-gold-500/25 transition-colors" placeholder="okul@university.edu.tr" />
            </div>
            <div>
              <label class="block text-text-secondary text-xs font-heading font-medium mb-1.5">LinkedIn</label>
              <input type="url" id="edit-linkedin" class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-text-primary text-sm font-body placeholder:text-text-secondary/40 focus:border-gold-500/50 focus:outline-none focus:ring-1 focus:ring-gold-500/25 transition-colors" placeholder="linkedin.com/in/..." />
            </div>
            <div>
              <label class="block text-text-secondary text-xs font-heading font-medium mb-1.5">Fikirler & Notlar</label>
              <textarea id="edit-ideas" rows="2" class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-text-primary text-sm font-body placeholder:text-text-secondary/40 focus:border-gold-500/50 focus:outline-none focus:ring-1 focus:ring-gold-500/25 transition-colors resize-none"></textarea>
            </div>
            <div>
              <label class="block text-text-secondary text-xs font-heading font-medium mb-2">Katkı Alanları</label>
              <div class="flex flex-wrap gap-2">
                <label class="flex items-center gap-2 text-sm text-text-secondary cursor-pointer"><input type="checkbox" name="edit-interests" value="projects" class="accent-[#D4A843]" /> Projelerde Yer Almak</label>
                <label class="flex items-center gap-2 text-sm text-text-secondary cursor-pointer"><input type="checkbox" name="edit-interests" value="workshops" class="accent-[#D4A843]" /> Atölye İçeriği</label>
                <label class="flex items-center gap-2 text-sm text-text-secondary cursor-pointer"><input type="checkbox" name="edit-interests" value="seminars" class="accent-[#D4A843]" /> Seminer Önermek</label>
                <label class="flex items-center gap-2 text-sm text-text-secondary cursor-pointer"><input type="checkbox" name="edit-interests" value="content" class="accent-[#D4A843]" /> İçerik Üretmek</label>
                <label class="flex items-center gap-2 text-sm text-text-secondary cursor-pointer"><input type="checkbox" name="edit-interests" value="mentorship" class="accent-[#D4A843]" /> Mentorluk</label>
              </div>
            </div>
            <div id="edit-error" class="hidden px-4 py-3 rounded-lg bg-red-500/10 border border-red-500/25 text-red-400 text-sm"></div>
            <div id="edit-success" class="hidden px-4 py-3 rounded-lg bg-green-500/10 border border-green-500/25 text-green-400 text-sm">Profil güncellendi!</div>
            <button id="edit-save" class="btn-gold justify-center text-sm py-2.5 px-6">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
              </svg>
              Kaydet
            </button>
          </div>
        </div>

        <!-- Contribution Preferences Section -->
        <div id="contribution-section" class="hidden glass rounded-2xl p-6 sm:p-8">
          <h2 class="text-lg font-heading font-bold text-text-primary mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 0 0-2.455 2.456ZM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423Z" />
            </svg>
            Katkı Tercihleri
          </h2>
          <div id="contribution-interests" class="flex flex-wrap gap-2 mb-4"></div>
          <div id="contribution-ideas" class="hidden">
            <p class="text-xs text-text-secondary font-heading font-medium mb-1.5">Fikirler & Notlar:</p>
            <p id="contribution-ideas-text" class="text-sm text-text-secondary/80 leading-relaxed"></p>
          </div>
          <div id="contribution-linkedin" class="hidden mt-3">
            <a id="contribution-linkedin-link" href="#" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-xs text-gold-500 hover:text-gold-300 transition-colors font-heading">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              LinkedIn Profili
            </a>
          </div>
          <div class="mt-4 px-4 py-3 rounded-lg bg-gold-500/5 border border-gold-500/15 text-xs text-text-secondary leading-relaxed">
            <span class="text-gold-500 font-heading font-medium">📬</span>
            Katılmak istediğiniz programlar ve fikirleriniz hakkında bize <a href="mailto:info@legereopenedu.com" class="text-gold-500 hover:text-gold-300 transition-colors">info@legereopenedu.com</a> adresinden yazabilirsiniz.
          </div>
        </div>

        <!-- Certificates Section -->
        <div class="glass rounded-2xl p-6 sm:p-8">
          <h2 class="text-lg font-heading font-bold text-text-primary mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
            </svg>
            {t('profile.certificates')}
            <span id="cert-count" class="text-sm font-normal text-text-secondary"></span>
          </h2>
          <div id="certificates-list" class="space-y-3">
            <p class="text-sm text-text-secondary">{t('profile.noCerts')}</p>
          </div>
        </div>

        <!-- Badges Section -->
        <div class="glass rounded-2xl p-6 sm:p-8">
          <h2 class="text-lg font-heading font-bold text-text-primary mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 0 1 3 3h-15a3 3 0 0 1 3-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 0 1-.982-3.172M9.497 14.25a7.454 7.454 0 0 0 .981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 0 0 7.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M18.75 4.236c.982.143 1.954.317 2.916.52A6.003 6.003 0 0 1 16.27 9.728M18.75 4.236V4.5c0 2.108-.966 3.99-2.48 5.228m0 0a6.023 6.023 0 0 1-2.77.896m5.25-6.388V2.721" />
            </svg>
            {t('profile.badges')}
            <span id="badge-count" class="text-sm font-normal text-text-secondary"></span>
          </h2>
          <div id="badges-list" class="flex flex-wrap gap-3">
            <p class="text-sm text-text-secondary">{t('profile.noBadges')}</p>
          </div>
        </div>

        <!-- Workshops Section -->
        <div class="glass rounded-2xl p-6 sm:p-8">
          <h2 class="text-lg font-heading font-bold text-text-primary mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
            </svg>
            {t('profile.workshops')}
          </h2>
          <div id="workshops-list" class="space-y-3">
            <p class="text-sm text-text-secondary">{t('profile.noWorkshops')}</p>
          </div>
        </div>

        <!-- Logout -->
        <div class="text-center pt-4">
          <button id="logout-btn" class="btn-outline text-sm py-2.5 px-6">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9" />
            </svg>
            {t('profile.logout')}
          </button>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script is:inline>
(function() {
  const LANG = 'tr';
  const BADGE_META = {
    'first-workshop':   { icon: '🎓', name: 'İlk Adım', desc: 'İlk atölyeyi tamamladı' },
    'three-workshops':  { icon: '⭐', name: 'Araştırmacı', desc: 'Üç atölye tamamladı' },
    'five-workshops':   { icon: '🏆', name: 'Uzman Araştırmacı', desc: 'Beş atölye tamamladı' },
    'multi-discipline': { icon: '🔗', name: 'Disiplinlerarası', desc: '3+ farklı disiplinden atölyelere katıldı' },
    'pioneer':          { icon: '🚀', name: 'Öncü', desc: 'Kurucu dönem katılımcısı' },
    'mentor':           { icon: '🧭', name: 'Mentor', desc: 'Mentorluk katkısında bulundu' },
    'contributor':      { icon: '✍️', name: 'Katkıcı', desc: 'Yayın sürecine aktif katkı' },
    'scholar':          { icon: '📖', name: 'Akademisyen', desc: 'Akademik yayın üretti' },
  };
  const CERT_TYPES = {
    'participation': 'Katılım Sertifikası',
    'achievement':   'Başarı Sertifikası',
    'contribution':  'Katkı Sertifikası',
  };
  const STATUS_MAP = {
    'completed': { label: 'Tamamlandı', cls: 'badge-open' },
    'accepted':  { label: 'Kabul Edildi', cls: 'badge-upcoming' },
    'pending':   { label: 'Beklemede', cls: 'badge-discipline' },
    'rejected':  { label: 'Reddedildi', cls: 'badge-closed' },
  };

  const loadingEl = document.getElementById('profile-loading');
  const contentEl = document.getElementById('profile-content');
  const notLoggedEl = document.getElementById('profile-not-logged-in');

  async function loadProfile() {
    try {
      const res = await fetch('/api/auth/me', { credentials: 'same-origin' });
      if (!res.ok) {
        loadingEl.classList.add('hidden');
        notLoggedEl.classList.remove('hidden');
        return;
      }
      const data = await res.json();
      renderProfile(data);
      loadingEl.classList.add('hidden');
      contentEl.classList.remove('hidden');
    } catch (err) {
      loadingEl.classList.add('hidden');
      notLoggedEl.classList.remove('hidden');
    }
  }

  function renderProfile(data) {
    const { user, registrations, certificates, badges } = data;

    // Avatar
    const initials = user.name ? user.name.split(' ').map(w => w[0]).join('').toUpperCase().slice(0, 2) : '?';
    document.getElementById('profile-avatar').textContent = initials;
    document.getElementById('profile-name').textContent = user.name || 'Üye';
    document.getElementById('profile-uni-text').textContent = user.university || '-';
    document.getElementById('profile-dept-text').textContent = user.department || '-';
    document.getElementById('profile-join-text').textContent = user.joinDate ? new Date(user.joinDate).toLocaleDateString('tr-TR', { year: 'numeric', month: 'long' }) : '-';

    // School email
    if (user.schoolEmail) {
      var schoolEmailEl = document.getElementById('profile-school-email');
      schoolEmailEl.classList.remove('hidden');
      document.getElementById('profile-school-email-text').textContent = user.schoolEmail;
    }

    // Privacy toggles
    const toggleFullName = document.getElementById('toggle-fullname');
    const toggleEmail = document.getElementById('toggle-email');
    toggleFullName.checked = user.showFullName ?? true;
    toggleEmail.checked = user.showEmail ?? false;

    toggleFullName.addEventListener('change', () => updatePrivacy({ showFullName: toggleFullName.checked }));
    toggleEmail.addEventListener('change', () => updatePrivacy({ showEmail: toggleEmail.checked }));

    // Populate edit form
    document.getElementById('edit-university').value = user.university || '';
    document.getElementById('edit-department').value = user.department || '';
    document.getElementById('edit-school-email').value = user.schoolEmail || '';
    document.getElementById('edit-linkedin').value = user.linkedin || '';
    document.getElementById('edit-ideas').value = user.ideas || '';
    if (user.interests) {
      user.interests.forEach(function(i) {
        var cb = document.querySelector('input[name="edit-interests"][value="' + i + '"]');
        if (cb) cb.checked = true;
      });
    }

    // Contribution preferences
    const INTEREST_LABELS = {
      'projects': 'Projelerde Yer Almak',
      'workshops': 'Atölye İçeriği Üretmek',
      'seminars': 'Seminer / Kolokyum Önermek',
      'content': 'İçerik Üretmek',
      'mentorship': 'Mentorluk Yapmak',
      'other': 'Diğer',
    };

    if ((user.interests && user.interests.length > 0) || user.ideas || user.linkedin) {
      const contSection = document.getElementById('contribution-section');
      contSection.classList.remove('hidden');

      if (user.interests && user.interests.length > 0) {
        const contInterests = document.getElementById('contribution-interests');
        contInterests.innerHTML = user.interests.map(function(i) {
          var label = INTEREST_LABELS[i] || i;
          return '<span class="badge badge-discipline">' + label + '</span>';
        }).join('');
      }

      if (user.ideas) {
        var ideasEl = document.getElementById('contribution-ideas');
        ideasEl.classList.remove('hidden');
        document.getElementById('contribution-ideas-text').textContent = user.ideas;
      }

      if (user.linkedin) {
        var linkedinEl = document.getElementById('contribution-linkedin');
        linkedinEl.classList.remove('hidden');
        document.getElementById('contribution-linkedin-link').href = user.linkedin;
      }
    }

    // Stats
    document.getElementById('stat-workshops').textContent = registrations.length;
    document.getElementById('stat-certificates').textContent = certificates.length;
    document.getElementById('stat-badges').textContent = badges.length;

    // Certificates
    if (certificates.length > 0) {
      document.getElementById('cert-count').textContent = `(${certificates.length})`;
      const certList = document.getElementById('certificates-list');
      certList.innerHTML = certificates.map(cert => {
        const typeLabel = CERT_TYPES[cert.type] || cert.type;
        const typeColor = cert.type === 'achievement' ? 'text-gold-300' : cert.type === 'contribution' ? 'text-status-upcoming' : 'text-status-open';
        return `
          <div class="glass-subtle p-4 flex flex-col sm:flex-row sm:items-center justify-between gap-3">
            <div class="min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-sm font-heading font-semibold ${typeColor}">${typeLabel}</span>
                <span class="text-xs font-mono text-text-secondary">${cert.id}</span>
              </div>
              <p class="text-xs text-text-secondary truncate">${cert.workshopTitle || cert.workshopId || '-'}</p>
              ${cert.issueDate ? `<p class="text-xs text-text-secondary/60 mt-0.5">${new Date(cert.issueDate).toLocaleDateString('tr-TR')}</p>` : ''}
            </div>
            <div class="flex items-center gap-2 shrink-0">
              <a href="/verify?cert=${cert.id}" class="text-xs text-gold-500 hover:text-gold-300 font-heading transition-colors">Doğrula</a>
              <button onclick="window.open('/verify?cert=${cert.id}&print=1','_blank')" class="btn-gold text-xs py-1.5 px-3">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
                </svg>
                İndir
              </button>
            </div>
          </div>
        `;
      }).join('');
    }

    // Badges
    if (badges.length > 0) {
      document.getElementById('badge-count').textContent = `(${badges.length})`;
      const badgesList = document.getElementById('badges-list');
      badgesList.innerHTML = badges.map(b => {
        const meta = BADGE_META[b.badgeId] || { icon: '🎖️', name: b.badgeId, desc: '' };
        return `
          <div class="glass-subtle px-4 py-3 rounded-xl flex items-center gap-3 group hover:border-gold-500/30 transition-colors" title="${meta.desc}">
            <span class="text-2xl">${meta.icon}</span>
            <div>
              <div class="text-sm font-heading font-semibold text-text-primary">${meta.name}</div>
              <div class="text-xs text-text-secondary">${meta.desc}</div>
            </div>
          </div>
        `;
      }).join('');
    }

    // Workshops
    if (registrations.length > 0) {
      const wsList = document.getElementById('workshops-list');
      wsList.innerHTML = registrations.map(r => {
        const status = STATUS_MAP[r.status] || STATUS_MAP['pending'];
        return `
          <div class="glass-subtle p-4 flex flex-col sm:flex-row sm:items-center justify-between gap-2">
            <div class="min-w-0">
              <p class="text-sm font-heading font-medium text-text-primary truncate">${r.workshop || r.id}</p>
              ${r.timestamp ? `<p class="text-xs text-text-secondary/60 mt-0.5">${new Date(r.timestamp).toLocaleDateString('tr-TR')}</p>` : ''}
            </div>
            <span class="badge ${status.cls} shrink-0">${status.label}</span>
          </div>
        `;
      }).join('');
    }
  }

  async function updatePrivacy(settings) {
    try {
      var res = await fetch('/api/auth/me', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'same-origin',
        body: JSON.stringify(settings),
      });
      if (!res.ok) console.warn('Gizlilik ayarları kaydedilemedi.');
    } catch (err) {
      console.warn('Gizlilik ayarları kaydedilemedi:', err);
    }
  }

  // Edit profile toggle
  var editToggle = document.getElementById('edit-toggle');
  var editContainer = document.getElementById('edit-form-container');
  var editChevron = document.getElementById('edit-chevron');
  editToggle.addEventListener('click', function() {
    editContainer.classList.toggle('hidden');
    editChevron.style.transform = editContainer.classList.contains('hidden') ? '' : 'rotate(180deg)';
  });

  // Edit profile save
  document.getElementById('edit-save').addEventListener('click', async function() {
    var editError = document.getElementById('edit-error');
    var editSuccess = document.getElementById('edit-success');
    editError.classList.add('hidden');
    editSuccess.classList.add('hidden');

    var interests = [];
    document.querySelectorAll('input[name="edit-interests"]:checked').forEach(function(cb) { interests.push(cb.value); });

    try {
      var res = await fetch('/api/auth/me', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'same-origin',
        body: JSON.stringify({
          university: document.getElementById('edit-university').value.trim(),
          department: document.getElementById('edit-department').value.trim(),
          schoolEmail: document.getElementById('edit-school-email').value.trim(),
          linkedin: document.getElementById('edit-linkedin').value.trim(),
          ideas: document.getElementById('edit-ideas').value.trim(),
          interests: interests,
        }),
      });
      if (res.ok) {
        editSuccess.classList.remove('hidden');
        setTimeout(function() { window.location.reload(); }, 1000);
      } else {
        var result = await res.json().catch(function() { return {}; });
        editError.textContent = result.error === 'School email already in use'
          ? 'Bu okul e-postası başka bir hesap tarafından kullanılıyor.'
          : result.error === 'Invalid school email format'
          ? 'Geçerli bir okul e-posta adresi girin.'
          : 'Bir hata oluştu. Lütfen tekrar deneyin.';
        editError.classList.remove('hidden');
      }
    } catch (err) {
      editError.textContent = 'Bağlantı hatası.';
      editError.classList.remove('hidden');
    }
  });

  // Logout (server-side token invalidation)
  document.getElementById('logout-btn')?.addEventListener('click', async () => {
    try {
      await fetch('/api/auth/me', { method: 'DELETE', credentials: 'same-origin' });
    } catch (err) {}
    document.cookie = 'legere_token=; Path=/; Max-Age=0; SameSite=Lax';
    window.location.href = '/';
  });

  loadProfile();
})();
</script>
