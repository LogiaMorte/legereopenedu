---
import Layout from '../layouts/Layout.astro';
import { useTranslations } from '../i18n/utils';
const lang = 'tr' as const;
const t = useTranslations(lang);
---

<Layout lang={lang} pageTitle="Üye Kayıt">
  <div class="relative min-h-screen pt-24 pb-16 px-4 sm:px-6 lg:px-8 flex items-center justify-center">
    <div class="w-full max-w-md">
      <a href="/" class="inline-flex items-center gap-2 text-gold-500 hover:text-gold-300 transition-colors font-heading text-sm mb-10 group">
        <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
        </svg>
        {t('login.back')}
      </a>

      <!-- Signup Card -->
      <div class="glass gold-glow rounded-2xl p-8">
        <!-- Form State -->
        <div id="signup-form-state">
          <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-gold-500/10 border border-gold-500/20 mb-4">
              <svg class="w-8 h-8 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M18 7.5v3m0 0v3m0-3h3m-3 0h-3m-2.25-4.125a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0ZM3 19.235v-.11a6.375 6.375 0 0 1 12.75 0v.109A12.318 12.318 0 0 1 9.374 21c-2.331 0-4.512-.645-6.374-1.766Z" />
              </svg>
            </div>
            <h1 class="text-2xl font-heading font-bold text-text-primary mb-2">{t('signup.title')}</h1>
            <p class="text-text-secondary text-sm leading-relaxed">{t('signup.desc')}</p>
          </div>

          <!-- Consent checkbox -->
          <div id="consent-section" class="hidden mb-4">
            <label class="flex items-start gap-3 cursor-pointer group">
              <input type="checkbox" id="consent-checkbox" class="mt-1 w-4 h-4 rounded border-white/20 bg-white/5 text-gold-500 focus:ring-gold-500/50 focus:ring-offset-0 cursor-pointer" />
              <span class="text-xs text-text-secondary leading-relaxed">
                <a href="/privacy/" class="text-gold-500 hover:text-gold-300 transition-colors">{t('signup.consentPrivacy')}</a>
                {' ve '}
                <a href="/terms/" class="text-gold-500 hover:text-gold-300 transition-colors">{t('signup.consentTerms')}</a>
                {' belgelerini okudum, kabul ediyorum.'}
              </span>
            </label>
          </div>

          <!-- Google Sign-In -->
          <div id="google-signin-section" class="hidden">
            <div id="google-btn" class="flex justify-center"></div>
          </div>

          <!-- LinkedIn Sign-Up (shown conditionally) -->
          <div id="linkedin-section" class="hidden">
            <div class="relative my-5">
              <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-white/10"></div></div>
              <div class="relative flex justify-center text-xs"><span class="bg-[#12121A] px-3 text-text-secondary">{t('signup.orLinkedin')}</span></div>
            </div>
            <a href="/api/auth/linkedin?mode=signup&lang=tr" class="w-full flex items-center justify-center gap-3 px-4 py-3 rounded-lg bg-[#0A66C2] hover:bg-[#004182] text-white text-sm font-heading font-medium transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              {t('signup.linkedinBtn')}
            </a>
            <div class="mt-4 px-4 py-3 rounded-lg bg-[#0A66C2]/5 border border-[#0A66C2]/15 text-xs text-text-secondary leading-relaxed">
              <span class="text-[#0A66C2] font-heading font-medium">LinkedIn</span> — {t('signup.linkedinBenefit')}
            </div>
          </div>

          <!-- Loading state -->
          <div id="auth-loading" class="flex justify-center py-4">
            <div class="inline-flex items-center gap-3 text-text-secondary font-heading text-sm">
              <svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
              </svg>
              Yükleniyor...
            </div>
          </div>

          <!-- Info note (shown when LinkedIn is not available) -->
          <div id="info-note" class="hidden mt-6 px-4 py-3 rounded-lg bg-gold-500/5 border border-gold-500/15 text-xs text-text-secondary leading-relaxed">
            <span class="text-gold-500 font-heading font-medium">💡</span>
            Google hesabınızla hızlıca kayıt olabilirsiniz. Profil bilgilerinizi (üniversite, bölüm vb.) kayıt olduktan sonra profilinizden düzenleyebilirsiniz.
          </div>

          <!-- Error message -->
          <div id="signup-error" class="hidden mt-4 px-4 py-3 rounded-lg bg-red-500/10 border border-red-500/25 text-red-400 text-sm"></div>

          <div class="mt-6 text-center">
            <span class="text-xs text-text-secondary">{t('signup.hasAccount')}</span>
            <a href="/login" class="text-xs text-gold-500 hover:text-gold-300 transition-colors font-heading ml-1">
              {t('signup.goLogin')}
            </a>
          </div>

          <!-- Data usage notice -->
          <div class="mt-5 pt-5 border-t border-white/5">
            <div class="flex items-start gap-2">
              <svg class="w-3.5 h-3.5 text-gold-500/60 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
              </svg>
              <p class="text-[11px] text-text-secondary/60 leading-relaxed">
                {t('login.dataNotice')}{' '}
                <a href="/privacy/" class="text-gold-500/70 hover:text-gold-500 transition-colors">{t('login.privacyLink')}</a>
                {' · '}
                <a href="/terms/" class="text-gold-500/70 hover:text-gold-500 transition-colors">{t('login.termsLink')}</a>
              </p>
            </div>
          </div>
        </div>

        <!-- Success State -->
        <div id="signup-success-state" class="hidden text-center py-8">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-status-open/10 border border-status-open/25 mb-4">
            <svg class="w-8 h-8 text-status-open" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
          </div>
          <h3 class="text-xl font-heading font-bold text-text-primary mb-2">{t('signup.success')}</h3>
          <p class="text-text-secondary text-sm mb-4">{t('signup.successDesc')}</p>
          <div class="px-4 py-3 rounded-lg bg-gold-500/5 border border-gold-500/15 text-xs text-text-secondary leading-relaxed mb-6 text-left">
            {t('signup.successEmailNote')}
          </div>
          <a href="/profile" class="btn-gold justify-center text-sm py-3 inline-flex">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
            </svg>
            {t('signup.goProfile')}
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script is:inline>
document.addEventListener('astro:page-load', function() {
  var loadingEl = document.getElementById('auth-loading');
  var errorEl = document.getElementById('signup-error');
  var formState = document.getElementById('signup-form-state');
  var successState = document.getElementById('signup-success-state');
  if (!loadingEl || !errorEl) return;

  // Check for success/error params from LinkedIn callback
  var params = new URLSearchParams(window.location.search);
  if (params.get('success') === 'new') {
    if (formState) formState.classList.add('hidden');
    if (successState) successState.classList.remove('hidden');
    loadingEl.classList.add('hidden');
    return;
  }
  if (params.get('error')) {
    errorEl.textContent = decodeURIComponent(params.get('error_description') || 'Kayıt başarısız.');
    errorEl.classList.remove('hidden');
  }

  fetch('/api/config').then(function(r) { return r.json(); }).then(function(cfg) {
    if (!cfg.googleClientId) {
      loadingEl.classList.add('hidden');
      errorEl.textContent = 'Kayıt sistemi yapılandırılmamış. Lütfen info@legereopenedu.com adresine yazın.';
      errorEl.classList.remove('hidden');
      return;
    }

    if (cfg.linkedinEnabled) {
      var li = document.getElementById('linkedin-section');
      if (li) li.classList.remove('hidden');
    } else {
      var info = document.getElementById('info-note');
      if (info) info.classList.remove('hidden');
    }

    // Consent checkbox controls
    var consentSection = document.getElementById('consent-section');
    var consentCheckbox = document.getElementById('consent-checkbox');
    var googleSection = document.getElementById('google-signin-section');
    var linkedinEl = document.getElementById('linkedin-section');
    if (consentSection) consentSection.classList.remove('hidden');

    function updateConsentState() {
      var accepted = consentCheckbox && consentCheckbox.checked;
      if (googleSection) googleSection.style.opacity = accepted ? '1' : '0.4';
      if (googleSection) googleSection.style.pointerEvents = accepted ? 'auto' : 'none';
      if (linkedinEl) linkedinEl.style.opacity = accepted ? '1' : '0.4';
      if (linkedinEl) linkedinEl.style.pointerEvents = accepted ? 'auto' : 'none';
    }
    if (consentCheckbox) consentCheckbox.addEventListener('change', updateConsentState);

    function initGoogle() {
      google.accounts.id.initialize({
        client_id: cfg.googleClientId,
        callback: function(response) {
          errorEl.classList.add('hidden');
          fetch('/api/auth/google', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'same-origin',
            body: JSON.stringify({ credential: response.credential }),
          }).then(function(res) {
            if (res.ok) {
              return res.json().then(function(data) {
                if (data.isNewMember) {
                  if (formState) formState.classList.add('hidden');
                  if (successState) successState.classList.remove('hidden');
                } else {
                  window.location.href = '/profile';
                }
              });
            } else {
              errorEl.textContent = 'Google ile kayıt başarısız. Lütfen tekrar deneyin.';
              errorEl.classList.remove('hidden');
            }
          }).catch(function() {
            errorEl.textContent = 'Bağlantı hatası. Lütfen tekrar deneyin.';
            errorEl.classList.remove('hidden');
          });
        }
      });
      google.accounts.id.renderButton(document.getElementById('google-btn'), {
        theme: 'filled_black', size: 'large', text: 'signup_with', shape: 'rectangular', width: 320
      });
      loadingEl.classList.add('hidden');
      googleSection.classList.remove('hidden');
      updateConsentState();
    }

    if (typeof google !== 'undefined' && google.accounts) {
      initGoogle();
    } else {
      var s = document.createElement('script');
      s.src = 'https://accounts.google.com/gsi/client';
      s.onload = initGoogle;
      document.head.appendChild(s);
    }
  }).catch(function() {
    loadingEl.classList.add('hidden');
    errorEl.textContent = 'Bağlantı hatası.';
    errorEl.classList.remove('hidden');
  });
});
</script>
