---
import Layout from '../../layouts/Layout.astro';
import { useTranslations } from '../../i18n/utils';

const lang = 'en' as const;
const t = useTranslations(lang);

const sections = [
  {
    id: 'intro',
    icon: 'info',
    title: t('privacy.intro.title'),
    paragraphs: [t('privacy.intro.p1'), t('privacy.intro.p2')],
  },
  {
    id: 'collection',
    icon: 'database',
    title: t('privacy.collection.title'),
    paragraphs: [t('privacy.collection.p1'), t('privacy.collection.p2'), t('privacy.collection.p3')],
  },
  {
    id: 'usage',
    icon: 'cog',
    title: t('privacy.usage.title'),
    paragraphs: [t('privacy.usage.p1'), t('privacy.usage.p2')],
  },
  {
    id: 'thirdParty',
    icon: 'link',
    title: t('privacy.thirdParty.title'),
    paragraphs: [t('privacy.thirdParty.p1'), t('privacy.thirdParty.p2')],
  },
  {
    id: 'age',
    icon: 'shield',
    title: t('privacy.age.title'),
    paragraphs: [t('privacy.age.p1')],
  },
  {
    id: 'rights',
    icon: 'shield',
    title: t('privacy.rights.title'),
    paragraphs: [t('privacy.rights.p1'), t('privacy.rights.p2')],
  },
  {
    id: 'changes',
    icon: 'pencil',
    title: t('privacy.changes.title'),
    paragraphs: [t('privacy.changes.p1')],
  },
  {
    id: 'contact',
    icon: 'mail',
    title: t('privacy.contact.title'),
    paragraphs: [t('privacy.contact.p1')],
  },
];

const icons: Record<string, string> = {
  info: 'M11.25 11.25l.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z',
  pencil: 'M16.862 4.487l1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10',
  database: 'M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125',
  cog: 'M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z',
  link: 'M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m9.86-2.822a4.5 4.5 0 0 0-1.242-7.244l-4.5-4.5a4.5 4.5 0 0 0-6.364 6.364l1.757 1.757',
  shield: 'M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z',
  mail: 'M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75',
};
---

<Layout lang={lang} pageTitle={t('privacy.title')} pageDescription={t('privacy.subtitle')}>
  <div class="relative min-h-screen pt-24 pb-16 px-4 sm:px-6 lg:px-8">
    <div class="absolute inset-0 pointer-events-none opacity-[0.02]" style="background-image: radial-gradient(circle at 1px 1px, #D4A843 1px, transparent 0); background-size: 48px 48px;"></div>

    <div class="max-w-4xl mx-auto relative">
      <a href="/en/" class="inline-flex items-center gap-2 text-gold-500 hover:text-gold-300 transition-colors font-heading text-sm mb-10 group">
        <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
        </svg>
        {t('privacy.back')}
      </a>

      <div class="text-center mb-16" data-animate>
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full glass-subtle text-gold-500 text-xs font-mono tracking-wider mb-6">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
          </svg>
          LEGERE OPEN EDU
        </div>
        <h1 class="text-3xl md:text-5xl font-heading font-bold text-text-primary mb-4">
          {t('privacy.title')}
        </h1>
        <p class="text-text-secondary text-lg max-w-2xl mx-auto">
          {t('privacy.subtitle')}
        </p>
      </div>

      <div class="space-y-10">
        {sections.map((section, idx) => (
          <article id={section.id} class="glass p-6 md:p-8" data-animate>
            <div class="flex items-start gap-4 mb-5">
              <div class="shrink-0 w-11 h-11 rounded-xl bg-gold-500/10 border border-gold-500/20 flex items-center justify-center">
                <svg class="w-5 h-5 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  {icons[section.icon].includes('M15 12a3') ? (
                    <Fragment>
                      <path stroke-linecap="round" stroke-linejoin="round" d={icons[section.icon].split(' M15')[0]} />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                    </Fragment>
                  ) : (
                    <path stroke-linecap="round" stroke-linejoin="round" d={icons[section.icon]} />
                  )}
                </svg>
              </div>
              <div>
                <span class="text-gold-500/60 text-xs font-mono tracking-wider">
                  {String(idx + 1).padStart(2, '0')}
                </span>
                <h2 class="text-xl md:text-2xl font-heading font-bold text-text-primary">
                  {section.title}
                </h2>
              </div>
            </div>
            <div class="space-y-3 pl-0 md:pl-15">
              {section.paragraphs.map((p) => (
                <p class="text-text-secondary text-sm leading-relaxed">
                  {p}
                </p>
              ))}
            </div>
          </article>
        ))}
      </div>

      <div class="mt-12 text-center text-text-secondary/40 text-xs font-mono">
        {t('privacy.lastUpdated')}: March 2026
      </div>
    </div>
  </div>
</Layout>
