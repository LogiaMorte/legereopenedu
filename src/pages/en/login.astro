---
import Layout from '../../layouts/Layout.astro';
import { useTranslations } from '../../i18n/utils';
const lang = 'en' as const;
const t = useTranslations(lang);
---

<Layout lang={lang} pageTitle="Member Login">
  <div class="relative min-h-screen pt-24 pb-16 px-4 sm:px-6 lg:px-8 flex items-center justify-center">
    <div class="w-full max-w-md">
      <a href="/en/" class="inline-flex items-center gap-2 text-gold-500 hover:text-gold-300 transition-colors font-heading text-sm mb-10 group">
        <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
        </svg>
        {t('login.back')}
      </a>

      <!-- Login Card -->
      <div class="glass gold-glow rounded-2xl p-8">
        <div class="text-center mb-8">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-gold-500/10 border border-gold-500/20 mb-4">
            <svg class="w-8 h-8 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
            </svg>
          </div>
          <h1 class="text-2xl font-heading font-bold text-text-primary mb-2">{t('login.title')}</h1>
          <p class="text-text-secondary text-sm leading-relaxed">{t('login.desc')}</p>
        </div>

        <!-- Google Sign-In -->
        <div id="google-signin-section" class="hidden mb-6">
          <div id="google-btn" class="flex justify-center"></div>
          <div class="relative my-5">
            <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-white/10"></div></div>
            <div class="relative flex justify-center text-xs"><span class="bg-[#12121A] px-3 text-text-secondary">or with email</span></div>
          </div>
        </div>

        <form id="login-form" class="space-y-4" novalidate>
          <div>
            <label for="login-email" class="block text-text-secondary text-xs font-heading font-medium mb-1.5">
              {t('login.email')}
            </label>
            <input
              type="email"
              id="login-email"
              required
              class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-text-primary text-sm font-body placeholder:text-text-secondary/40 focus:border-gold-500/50 focus:outline-none focus:ring-1 focus:ring-gold-500/25 transition-colors"
              placeholder={t('login.emailHint')}
            />
          </div>

          <div>
            <label for="login-password" class="block text-text-secondary text-xs font-heading font-medium mb-1.5">
              {t('login.password')}
            </label>
            <input
              type="text"
              id="login-password"
              required
              autocomplete="off"
              class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-text-primary text-sm font-mono uppercase tracking-wider placeholder:text-text-secondary/40 placeholder:normal-case placeholder:tracking-normal focus:border-gold-500/50 focus:outline-none focus:ring-1 focus:ring-gold-500/25 transition-colors"
              placeholder={t('login.passwordHint')}
            />
          </div>

          <div id="login-error" class="hidden px-4 py-3 rounded-lg bg-red-500/10 border border-red-500/25 text-red-400 text-sm">
            {t('login.error')}
          </div>

          <button type="submit" id="login-submit" class="w-full btn-gold justify-center text-sm py-3">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9" />
            </svg>
            <span id="login-submit-text">{t('login.submit')}</span>
          </button>
        </form>

        <div class="mt-4 flex items-center justify-between">
          <a href="#" id="forgot-link" class="text-xs text-text-secondary hover:text-gold-500 transition-colors font-heading">
            {t('login.forgotPassword')}
          </a>
          <span class="text-xs text-text-secondary">
            <a href="/en/signup" class="text-gold-500 hover:text-gold-300 transition-colors font-heading">
              {t('nav.signup')}
            </a>
          </span>
        </div>

        <!-- Data usage notice for Google OAuth compliance -->
        <div class="mt-6 pt-5 border-t border-white/5">
          <div class="flex items-start gap-2">
            <svg class="w-3.5 h-3.5 text-gold-500/60 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
            </svg>
            <p class="text-[11px] text-text-secondary/60 leading-relaxed">
              {t('login.dataNotice')}{' '}
              <a href="/en/privacy/" class="text-gold-500/70 hover:text-gold-500 transition-colors">{t('login.privacyLink')}</a>
              {' · '}
              <a href="/en/terms/" class="text-gold-500/70 hover:text-gold-500 transition-colors">{t('login.termsLink')}</a>
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script is:inline>
(function() {
  fetch('/api/config').then(function(r) { return r.json(); }).then(function(cfg) {
    if (!cfg.googleClientId) return;
    var s = document.createElement('script');
    s.src = 'https://accounts.google.com/gsi/client';
    s.onload = function() {
      google.accounts.id.initialize({
        client_id: cfg.googleClientId,
        callback: function(response) {
          var errorEl = document.getElementById('login-error');
          fetch('/api/auth/google', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'same-origin',
            body: JSON.stringify({ credential: response.credential }),
          }).then(function(res) {
            if (res.ok) {
              window.location.href = '/en/profile';
            } else {
              errorEl.textContent = 'Google sign-in failed.';
              errorEl.classList.remove('hidden');
            }
          }).catch(function() {
            errorEl.textContent = 'Connection error.';
            errorEl.classList.remove('hidden');
          });
        }
      });
      google.accounts.id.renderButton(document.getElementById('google-btn'), {
        theme: 'filled_black', size: 'large', text: 'signin_with', shape: 'rectangular', width: 320
      });
      document.getElementById('google-signin-section').classList.remove('hidden');
    };
    document.head.appendChild(s);
  }).catch(function() {});
})();
</script>
<script is:inline>
(function() {
  var form = document.getElementById('login-form');
  var submitBtn = document.getElementById('login-submit');
  var submitText = document.getElementById('login-submit-text');
  var errorEl = document.getElementById('login-error');
  var forgotLink = document.getElementById('forgot-link');

  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    var email = document.getElementById('login-email').value.trim();
    var password = document.getElementById('login-password').value.trim().toUpperCase();

    if (!email || !password) {
      errorEl.classList.remove('hidden');
      return;
    }

    errorEl.classList.add('hidden');
    submitBtn.disabled = true;
    submitText.textContent = 'Logging in...';

    try {
      var res = await fetch('/api/auth/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'same-origin',
        body: JSON.stringify({ email: email, password: password }),
      });

      if (res.ok) {
        window.location.href = '/en/profile';
      } else {
        var result = await res.json().catch(function() { return {}; });
        console.error('[login] Server error:', res.status, result);
        if (result.error === 'Invalid credentials') {
          errorEl.textContent = 'Invalid email or password.';
        } else if (result.error === 'Email and password required') {
          errorEl.textContent = 'Please enter your email and password.';
        } else {
          errorEl.textContent = 'An error occurred (' + res.status + '). Please try again.';
        }
        errorEl.classList.remove('hidden');
      }
    } catch (err) {
      console.error('[login] Network error:', err);
      errorEl.textContent = 'Connection error. Please check your internet.';
      errorEl.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitText.textContent = 'Log In';
    }
  });

  // Forgot password — inline recovery
  forgotLink.addEventListener('click', function(e) {
    e.preventDefault();
    var email = document.getElementById('login-email').value.trim();
    if (!email) {
      document.getElementById('login-email').focus();
      return;
    }
    forgotLink.textContent = 'Sending...';
    fetch('/api/auth/recover', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email: email }),
    }).then(function() {
      forgotLink.textContent = 'New password sent! Check your email.';
      forgotLink.style.color = '#4ADE80';
    }).catch(function() {
      forgotLink.textContent = 'Forgot Password';
    });
  });
})();
</script>
