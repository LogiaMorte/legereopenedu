---
import Layout from '../layouts/Layout.astro';
const lang = 'tr' as const;
---

<Layout lang={lang} pageTitle="Admin Panel">
  <div class="relative min-h-screen pt-24 pb-16 px-4 sm:px-6 lg:px-8">
    <div class="max-w-6xl mx-auto">
      <a href="/" class="inline-flex items-center gap-2 text-gold-500 hover:text-gold-300 transition-colors font-heading text-sm mb-10 group">
        <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
        </svg>
        Ana Sayfaya Dön
      </a>

      <h1 class="text-3xl font-heading font-bold text-text-primary mb-2">Admin Panel</h1>
      <p class="text-text-secondary text-sm mb-8">Başvuruları ve üyeleri yönetin.</p>

      <!-- Auth -->
      <div id="auth-section" class="glass p-6 mb-8">
        <label for="admin-key" class="block text-text-secondary text-xs font-heading font-medium mb-2">Admin Anahtarı</label>
        <div class="flex gap-3">
          <input type="password" id="admin-key" class="flex-1 px-4 py-2.5 rounded-lg bg-white/5 border border-white/10 text-text-primary text-sm font-mono placeholder:text-text-secondary/40 focus:border-gold-500/50 focus:outline-none" placeholder="ADMIN_KEY değerinizi girin" />
          <button id="fetch-btn" class="btn-gold text-sm px-6" onclick="loadAll()">Yükle</button>
        </div>
      </div>

      <!-- Admin Tabs -->
      <div id="admin-tabs" class="hidden flex gap-1 bg-white/[0.02] rounded-xl p-1 border border-white/5 mb-8">
        <button class="admin-tab flex-1 px-4 py-2.5 rounded-lg text-sm font-heading font-medium transition-all bg-gold-500/10 text-gold-500 border border-gold-500/20" data-tab="registrations" onclick="switchAdminTab('registrations')">
          Başvurular
          <span id="tab-reg-count" class="ml-1.5 px-1.5 py-0.5 rounded-full bg-gold-500/20 text-gold-500 text-[10px] font-mono"></span>
        </button>
        <button class="admin-tab flex-1 px-4 py-2.5 rounded-lg text-sm font-heading font-medium transition-all text-text-secondary" data-tab="members" onclick="switchAdminTab('members')">
          Üyeler
          <span id="tab-member-count" class="ml-1.5 px-1.5 py-0.5 rounded-full bg-gold-500/20 text-gold-500 text-[10px] font-mono"></span>
        </button>
      </div>

      <!-- ==================== REGISTRATIONS TAB ==================== -->
      <div id="panel-registrations">
        <!-- Stats -->
        <div id="stats-section" class="hidden grid grid-cols-3 md:grid-cols-6 gap-4 mb-8">
          <div class="glass p-4 text-center">
            <div id="stat-total" class="text-2xl font-heading font-bold text-gradient-gold">0</div>
            <div class="text-text-secondary text-xs">Toplam</div>
          </div>
          <div class="glass p-4 text-center">
            <div id="stat-pending" class="text-2xl font-heading font-bold text-yellow-400">0</div>
            <div class="text-text-secondary text-xs">Bekleyen</div>
          </div>
          <div class="glass p-4 text-center">
            <div id="stat-accepted" class="text-2xl font-heading font-bold text-status-open">0</div>
            <div class="text-text-secondary text-xs">Kabul</div>
          </div>
          <div class="glass p-4 text-center">
            <div id="stat-completed" class="text-2xl font-heading font-bold text-status-upcoming">0</div>
            <div class="text-text-secondary text-xs">Tamamlanan</div>
          </div>
          <div class="glass p-4 text-center">
            <div id="stat-rejected" class="text-2xl font-heading font-bold text-status-closed">0</div>
            <div class="text-text-secondary text-xs">Red</div>
          </div>
          <div class="glass p-4 text-center">
            <div id="stat-workshops" class="text-2xl font-heading font-bold text-gradient-gold">0</div>
            <div class="text-text-secondary text-xs">Atölye</div>
          </div>
        </div>

        <!-- Filter tabs -->
        <div id="filter-section" class="hidden flex gap-2 mb-6 flex-wrap">
          <button class="filter-btn badge badge-discipline text-xs cursor-pointer" data-filter="all" onclick="filterRegs('all')">Tümü</button>
          <button class="filter-btn badge text-xs cursor-pointer bg-yellow-500/10 text-yellow-400 border-yellow-500/25" data-filter="pending" onclick="filterRegs('pending')">Bekleyen</button>
          <button class="filter-btn badge text-xs cursor-pointer bg-status-open/10 text-status-open border-status-open/25" data-filter="accepted" onclick="filterRegs('accepted')">Kabul</button>
          <button class="filter-btn badge text-xs cursor-pointer bg-status-upcoming/10 text-status-upcoming border-status-upcoming/25" data-filter="completed" onclick="filterRegs('completed')">Tamamlanan</button>
          <button class="filter-btn badge text-xs cursor-pointer bg-status-closed/10 text-status-closed border-status-closed/25" data-filter="rejected" onclick="filterRegs('rejected')">Red</button>
        </div>

        <!-- Cards list -->
        <div id="cards-section" class="hidden space-y-4"></div>

        <!-- Export -->
        <div id="export-section" class="hidden mt-6 flex justify-end">
          <button class="btn-outline text-xs" onclick="exportCSV()">CSV İndir</button>
        </div>

        <!-- Empty state -->
        <div id="empty-state" class="hidden glass p-12 text-center">
          <p class="text-text-secondary">Henüz başvuru bulunmuyor.</p>
        </div>
      </div>

      <!-- ==================== MEMBERS TAB ==================== -->
      <div id="panel-members" class="hidden">
        <!-- Search -->
        <div class="glass p-4 mb-6">
          <input type="text" id="member-search" class="w-full px-4 py-2.5 rounded-lg bg-white/5 border border-white/10 text-text-primary text-sm placeholder:text-text-secondary/40 focus:border-gold-500/50 focus:outline-none" placeholder="Üye ara (isim veya e-posta)..." oninput="filterMembers()" />
        </div>

        <!-- Members list -->
        <div id="members-list" class="space-y-3"></div>

        <!-- Members empty -->
        <div id="members-empty" class="hidden glass p-12 text-center">
          <p class="text-text-secondary">Henüz üye bulunmuyor.</p>
        </div>

        <!-- Members export -->
        <div id="members-export" class="hidden mt-6 flex justify-end">
          <button class="btn-outline text-xs" onclick="exportMembersCSV()">CSV İndir</button>
        </div>
      </div>

      <!-- Error state -->
      <div id="error-state" class="hidden glass p-6 text-center">
        <p class="text-red-400 text-sm">Yüklenirken bir hata oluştu. Anahtarınızı kontrol edin.</p>
      </div>
    </div>
  </div>

  <!-- Action Modal -->
  <div id="action-modal" class="fixed inset-0 z-[100] hidden items-center justify-center p-4">
    <div id="action-backdrop" class="absolute inset-0 bg-black/70 backdrop-blur-sm"></div>
    <div class="relative w-full max-w-md glass gold-glow rounded-2xl p-6">
      <h3 id="action-modal-title" class="text-lg font-heading font-bold text-text-primary mb-4"></h3>
      <p id="action-modal-info" class="text-text-secondary text-sm mb-4"></p>
      <textarea id="action-message" rows="3" class="w-full px-4 py-2.5 rounded-lg bg-white/5 border border-white/10 text-text-primary text-sm placeholder:text-text-secondary/40 focus:border-gold-500/50 focus:outline-none resize-none mb-4" placeholder="Kişiye özel mesaj ekleyin (opsiyonel)"></textarea>
      <div class="flex gap-3">
        <button id="action-cancel" class="btn-outline text-sm flex-1" onclick="closeActionModal()">İptal</button>
        <button id="action-confirm" class="btn-gold text-sm flex-1" onclick="confirmAction()">Onayla</button>
      </div>
    </div>
  </div>

  <!-- Certificate Modal -->
  <div id="cert-modal" class="fixed inset-0 z-[100] hidden items-center justify-center p-4">
    <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" onclick="closeCertModal()"></div>
    <div class="relative w-full max-w-md glass gold-glow rounded-2xl p-6">
      <h3 class="text-lg font-heading font-bold text-text-primary mb-4">Sertifika Ver</h3>
      <p id="cert-modal-info" class="text-text-secondary text-sm mb-4"></p>
      <div class="mb-4">
        <label class="block text-text-secondary text-xs font-heading font-medium mb-1.5">Sertifika Türü</label>
        <select id="cert-type-select" class="w-full px-4 py-2.5 rounded-lg bg-white/5 border border-white/10 text-text-primary text-sm focus:border-gold-500/50 focus:outline-none">
          <option value="participation">Katılım Sertifikası</option>
          <option value="achievement">Başarı Sertifikası</option>
          <option value="contribution">Katkı Sertifikası</option>
        </select>
      </div>
      <div class="flex gap-3">
        <button class="btn-outline text-sm flex-1" onclick="closeCertModal()">İptal</button>
        <button id="cert-confirm" class="btn-gold text-sm flex-1" onclick="confirmCert()">Sertifika Ver</button>
      </div>
    </div>
  </div>

  <!-- Badge Modal -->
  <div id="badge-modal" class="fixed inset-0 z-[100] hidden items-center justify-center p-4">
    <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" onclick="closeBadgeModal()"></div>
    <div class="relative w-full max-w-md glass gold-glow rounded-2xl p-6">
      <h3 class="text-lg font-heading font-bold text-text-primary mb-4">Rozet Ver</h3>
      <p id="badge-modal-info" class="text-text-secondary text-sm mb-4"></p>
      <div class="mb-4">
        <label class="block text-text-secondary text-xs font-heading font-medium mb-1.5">Rozet</label>
        <select id="badge-select" class="w-full px-4 py-2.5 rounded-lg bg-white/5 border border-white/10 text-text-primary text-sm focus:border-gold-500/50 focus:outline-none">
          <option value="pioneer">Öncü — Kurucu dönem katılımcısı</option>
          <option value="mentor">Mentor — Mentorluk katkısı</option>
          <option value="contributor">Katkıcı — Yayın sürecine katkı</option>
          <option value="scholar">Akademisyen — Akademik yayın üretti</option>
        </select>
      </div>
      <div class="flex gap-3">
        <button class="btn-outline text-sm flex-1" onclick="closeBadgeModal()">İptal</button>
        <button id="badge-confirm" class="btn-gold text-sm flex-1" onclick="confirmBadge()">Rozet Ver</button>
      </div>
    </div>
  </div>

  <!-- Member Detail Modal -->
  <div id="member-detail-modal" class="fixed inset-0 z-[100] hidden items-center justify-center p-4">
    <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" onclick="closeMemberDetail()"></div>
    <div class="relative w-full max-w-lg max-h-[80vh] overflow-y-auto glass gold-glow rounded-2xl p-6">
      <button onclick="closeMemberDetail()" class="absolute top-4 right-4 w-8 h-8 flex items-center justify-center rounded-full glass-subtle hover:bg-white/10 transition-colors">
        <svg class="w-4 h-4 text-text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" /></svg>
      </button>
      <div id="member-detail-content"></div>
    </div>
  </div>
</Layout>

<script is:inline>
  var allRegistrations = [];
  var allMembers = [];
  var currentFilter = 'all';
  var pendingAction = null;
  var pendingCertRegId = null;
  var pendingBadgeRegId = null;

  function switchAdminTab(tab) {
    document.querySelectorAll('.admin-tab').forEach(function(t) {
      if (t.dataset.tab === tab) {
        t.classList.add('bg-gold-500/10', 'text-gold-500', 'border', 'border-gold-500/20');
        t.classList.remove('text-text-secondary');
      } else {
        t.classList.remove('bg-gold-500/10', 'text-gold-500', 'border', 'border-gold-500/20');
        t.classList.add('text-text-secondary');
      }
    });
    document.getElementById('panel-registrations').classList.toggle('hidden', tab !== 'registrations');
    document.getElementById('panel-members').classList.toggle('hidden', tab !== 'members');
  }

  async function loadAll() {
    var key = document.getElementById('admin-key').value.trim();
    if (!key) return;
    var btn = document.getElementById('fetch-btn');
    btn.textContent = 'Yükleniyor...';
    btn.disabled = true;

    try {
      // Load registrations and members in parallel
      var [regRes, memRes] = await Promise.all([
        fetch('/api/registrations', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ key: key, action: 'list' }) }),
        fetch('/api/auth/members', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ key: key, action: 'list' }) })
      ]);

      if (!regRes.ok) throw new Error((await regRes.json().catch(function(){return {};}).then(function(d){return d.error;})) || 'HTTP ' + regRes.status);

      var regData = await regRes.json();
      allRegistrations = regData.registrations || [];
      updateStats();
      renderCards();
      document.getElementById('stats-section').classList.remove('hidden');
      document.getElementById('filter-section').classList.remove('hidden');
      document.getElementById('export-section').classList.remove('hidden');
      document.getElementById('error-state').classList.add('hidden');
      document.getElementById('admin-tabs').classList.remove('hidden');
      document.getElementById('tab-reg-count').textContent = allRegistrations.length;

      if (memRes.ok) {
        var memData = await memRes.json();
        allMembers = memData.members || [];
        document.getElementById('tab-member-count').textContent = allMembers.length;
        renderMembers();
      }
    } catch (err) {
      var errorEl = document.getElementById('error-state');
      errorEl.querySelector('p').textContent = err.message === 'Unauthorized'
        ? 'Yanlış anahtar.'
        : 'Hata: ' + err.message;
      errorEl.classList.remove('hidden');
    } finally {
      btn.textContent = 'Yükle';
      btn.disabled = false;
    }
  }

  function updateStats() {
    var pending = allRegistrations.filter(function(r){return !r.status || r.status === 'pending';}).length;
    var accepted = allRegistrations.filter(function(r){return r.status === 'accepted';}).length;
    var completed = allRegistrations.filter(function(r){return r.status === 'completed';}).length;
    var rejected = allRegistrations.filter(function(r){return r.status === 'rejected';}).length;
    var workshops = new Set(allRegistrations.map(function(r){return r.workshop;}));
    document.getElementById('stat-total').textContent = allRegistrations.length;
    document.getElementById('stat-pending').textContent = pending;
    document.getElementById('stat-accepted').textContent = accepted;
    document.getElementById('stat-completed').textContent = completed;
    document.getElementById('stat-rejected').textContent = rejected;
    document.getElementById('stat-workshops').textContent = workshops.size;
  }

  function filterRegs(filter) {
    currentFilter = filter;
    document.querySelectorAll('.filter-btn').forEach(function(b){b.style.opacity='0.5';});
    document.querySelector('[data-filter="'+filter+'"]').style.opacity = '1';
    renderCards();
  }

  function renderCards() {
    var container = document.getElementById('cards-section');
    var filtered = allRegistrations;
    if (currentFilter !== 'all') {
      filtered = allRegistrations.filter(function(r) { return (r.status || 'pending') === currentFilter; });
    }
    if (filtered.length === 0) { container.classList.add('hidden'); document.getElementById('empty-state').classList.remove('hidden'); return; }
    container.classList.remove('hidden');
    document.getElementById('empty-state').classList.add('hidden');
    container.innerHTML = filtered.map(function(r) {
      var status = r.status || 'pending';
      var statusBadge = status === 'accepted' ? '<span class="badge text-xs bg-status-open/10 text-status-open border-status-open/25">Kabul</span>'
        : status === 'completed' ? '<span class="badge text-xs bg-status-upcoming/10 text-status-upcoming border-status-upcoming/25">Tamamlandı</span>'
        : status === 'rejected' ? '<span class="badge text-xs bg-status-closed/10 text-status-closed border-status-closed/25">Red</span>'
        : '<span class="badge text-xs bg-yellow-500/10 text-yellow-400 border-yellow-500/25">Bekleyen</span>';
      var actions = '';
      if (status === 'pending') {
        actions = '<div class="flex gap-2 mt-4 pt-4 border-t border-white/5"><button data-action="accept" data-reg-id="'+escAttr(r.id)+'" data-name="'+escAttr(r.name)+'" class="action-btn flex-1 py-2 px-3 rounded-lg bg-status-open/10 border border-status-open/25 text-status-open text-xs font-heading font-medium hover:bg-status-open/20 transition-colors cursor-pointer">Kabul Et</button><button data-action="reject" data-reg-id="'+escAttr(r.id)+'" data-name="'+escAttr(r.name)+'" class="action-btn flex-1 py-2 px-3 rounded-lg bg-status-closed/10 border border-status-closed/25 text-status-closed text-xs font-heading font-medium hover:bg-status-closed/20 transition-colors cursor-pointer">Reddet</button></div>';
      } else if (status === 'accepted' || status === 'completed') {
        actions = '<div class="flex gap-2 mt-4 pt-4 border-t border-white/5"><button data-action="cert" data-reg-id="'+escAttr(r.id)+'" data-name="'+escAttr(r.name)+'" data-workshop="'+escAttr(r.workshop)+'" class="action-btn flex-1 py-2 px-3 rounded-lg bg-gold-500/10 border border-gold-500/25 text-gold-500 text-xs font-heading font-medium hover:bg-gold-500/20 transition-colors cursor-pointer">Sertifika Ver</button><button data-action="badge" data-reg-id="'+escAttr(r.id)+'" data-name="'+escAttr(r.name)+'" class="action-btn flex-1 py-2 px-3 rounded-lg bg-purple-500/10 border border-purple-500/25 text-purple-400 text-xs font-heading font-medium hover:bg-purple-500/20 transition-colors cursor-pointer">Rozet Ver</button></div>';
      }
      return '<div class="glass p-5 hover:border-gold-500/15 transition-all"><div class="flex items-start justify-between gap-4 mb-3"><div><h3 class="font-heading font-bold text-text-primary text-sm">'+esc(r.name)+'</h3><p class="text-text-secondary/60 text-xs font-mono">'+esc(r.email)+'</p></div>'+statusBadge+'</div><div class="grid grid-cols-2 md:grid-cols-4 gap-3 text-xs"><div><span class="text-text-secondary/50">Üniversite:</span><br><span class="text-text-secondary">'+esc(r.university)+'</span></div><div><span class="text-text-secondary/50">Bölüm:</span><br><span class="text-text-secondary">'+esc(r.department)+'</span></div><div><span class="text-text-secondary/50">Atölye:</span><br><span class="text-gold-500">'+esc(r.workshop)+'</span></div><div><span class="text-text-secondary/50">Tarih:</span><br><span class="text-text-secondary font-mono">'+formatTS(r.timestamp)+'</span></div></div>'+(r.motivation?'<div class="mt-3 p-3 rounded-lg bg-white/[0.02] border border-white/5"><p class="text-text-secondary text-xs leading-relaxed"><span class="text-text-secondary/50">Motivasyon: </span>'+esc(r.motivation)+'</p></div>':'')+actions+'</div>';
    }).join('');
  }

  // Members rendering
  function renderMembers() {
    var container = document.getElementById('members-list');
    var search = (document.getElementById('member-search').value || '').toLowerCase().trim();
    var filtered = allMembers;
    if (search) {
      filtered = allMembers.filter(function(m) {
        return (m.name||'').toLowerCase().indexOf(search) > -1 || (m.email||'').toLowerCase().indexOf(search) > -1;
      });
    }
    if (filtered.length === 0) {
      container.classList.add('hidden');
      document.getElementById('members-empty').classList.remove('hidden');
      document.getElementById('members-export').classList.add('hidden');
      return;
    }
    container.classList.remove('hidden');
    document.getElementById('members-empty').classList.add('hidden');
    document.getElementById('members-export').classList.remove('hidden');

    var sourceLabels = { 'google': 'Google', 'linkedin': 'LinkedIn', 'self': 'E-posta', 'unknown': '-' };
    container.innerHTML = filtered.map(function(m) {
      return '<div class="glass p-4 hover:border-gold-500/15 transition-all cursor-pointer" onclick="openMemberDetail(\''+escAttr(m.email)+'\')">'
        + '<div class="flex items-center justify-between gap-4">'
        + '<div class="min-w-0">'
        + '<h3 class="font-heading font-bold text-text-primary text-sm truncate">'+esc(m.name || 'İsimsiz')+'</h3>'
        + '<p class="text-text-secondary/60 text-xs font-mono truncate">'+esc(m.email)+'</p>'
        + '</div>'
        + '<div class="flex items-center gap-3 shrink-0 text-xs">'
        + '<span class="badge badge-discipline">'+(sourceLabels[m.signupSource] || m.signupSource)+'</span>'
        + '<span class="text-text-secondary">' + m.registrationCount + ' etkinlik</span>'
        + '<span class="text-text-secondary font-mono">'+(m.joinDate ? new Date(m.joinDate).toLocaleDateString('tr-TR',{day:'numeric',month:'short',year:'numeric'}) : '-')+'</span>'
        + '</div></div>'
        + '<div class="flex gap-4 mt-2 text-xs text-text-secondary/60">'
        + '<span>'+esc(m.university || '-')+'</span>'
        + '<span>'+esc(m.department || '-')+'</span>'
        + '</div></div>';
    }).join('');
  }

  function filterMembers() { renderMembers(); }

  async function openMemberDetail(email) {
    var key = document.getElementById('admin-key').value.trim();
    var modal = document.getElementById('member-detail-modal');
    var content = document.getElementById('member-detail-content');
    content.innerHTML = '<div class="text-center py-8 text-text-secondary text-sm">Yükleniyor...</div>';
    modal.classList.remove('hidden');
    modal.classList.add('flex');

    try {
      var res = await fetch('/api/auth/members', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ key: key, action: 'detail', email: email })
      });
      if (!res.ok) throw new Error('Detay yüklenemedi');
      var data = await res.json();
      var m = data.member;
      var regs = data.registrations || [];
      var certs = data.certificates || [];
      var badges = data.badges || [];

      content.innerHTML = '<h3 class="text-lg font-heading font-bold text-text-primary mb-4">'+esc(m.name || 'İsimsiz')+'</h3>'
        + '<div class="space-y-3 text-sm">'
        + '<div class="grid grid-cols-2 gap-3">'
        + '<div><span class="text-text-secondary/50 text-xs">E-posta</span><p class="text-text-primary font-mono text-xs truncate">'+esc(m.email)+'</p></div>'
        + (m.schoolEmail ? '<div><span class="text-text-secondary/50 text-xs">Okul E-postası</span><p class="text-text-primary font-mono text-xs truncate">'+esc(m.schoolEmail)+'</p></div>' : '')
        + '<div><span class="text-text-secondary/50 text-xs">Üniversite</span><p class="text-text-primary text-xs">'+esc(m.university || '-')+'</p></div>'
        + '<div><span class="text-text-secondary/50 text-xs">Bölüm</span><p class="text-text-primary text-xs">'+esc(m.department || '-')+'</p></div>'
        + '<div><span class="text-text-secondary/50 text-xs">Kayıt Tarihi</span><p class="text-text-primary text-xs">'+(m.joinDate ? new Date(m.joinDate).toLocaleDateString('tr-TR') : '-')+'</p></div>'
        + '<div><span class="text-text-secondary/50 text-xs">Kayıt Kaynağı</span><p class="text-text-primary text-xs">'+esc(m.signupSource || '-')+'</p></div>'
        + '</div>'
        + (m.linkedin ? '<div><span class="text-text-secondary/50 text-xs">LinkedIn</span><p><a href="'+esc(m.linkedin)+'" target="_blank" class="text-gold-500 text-xs hover:text-gold-300">'+esc(m.linkedin)+'</a></p></div>' : '')
        + (m.interests && m.interests.length > 0 ? '<div><span class="text-text-secondary/50 text-xs">İlgi Alanları</span><div class="flex flex-wrap gap-1 mt-1">'+m.interests.map(function(i){return '<span class="badge badge-discipline text-[10px]">'+esc(i)+'</span>';}).join('')+'</div></div>' : '')
        + (m.ideas ? '<div><span class="text-text-secondary/50 text-xs">Fikirler</span><p class="text-text-secondary text-xs">'+esc(m.ideas)+'</p></div>' : '')
        + '</div>'
        + (regs.length > 0 ? '<h4 class="text-sm font-heading font-bold text-text-primary mt-6 mb-3">Etkinlikler ('+regs.length+')</h4><div class="space-y-2">'+regs.map(function(r){
          var statusMap = { completed:'Tamamlandı', accepted:'Kabul', pending:'Beklemede', rejected:'Red' };
          return '<div class="glass-subtle p-3 flex justify-between items-center"><span class="text-xs text-text-primary truncate">'+esc(r.workshop||r.id)+'</span><span class="badge text-[10px] badge-discipline">'+(statusMap[r.status]||r.status)+'</span></div>';
        }).join('')+'</div>' : '')
        + (certs.length > 0 ? '<h4 class="text-sm font-heading font-bold text-text-primary mt-6 mb-3">Sertifikalar ('+certs.length+')</h4><div class="space-y-2">'+certs.map(function(c){
          return '<div class="glass-subtle p-3 text-xs"><span class="text-gold-500 font-mono">'+esc(c.id)+'</span> — '+esc(c.type||'')+'</div>';
        }).join('')+'</div>' : '')
        + (badges.length > 0 ? '<h4 class="text-sm font-heading font-bold text-text-primary mt-6 mb-3">Rozetler ('+badges.length+')</h4><div class="space-y-2">'+badges.map(function(b){
          return '<div class="glass-subtle p-3 text-xs">'+esc(b.badgeId)+'</div>';
        }).join('')+'</div>' : '');
    } catch (err) {
      content.innerHTML = '<p class="text-red-400 text-sm">Detay yüklenemedi.</p>';
    }
  }

  function closeMemberDetail() {
    var modal = document.getElementById('member-detail-modal');
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  }

  // Event delegation for action buttons
  document.getElementById('cards-section').addEventListener('click', function(e) {
    var btn = e.target.closest('.action-btn');
    if (!btn) return;
    var action = btn.dataset.action;
    var regId = btn.dataset.regId;
    var name = btn.dataset.name;
    var workshop = btn.dataset.workshop;
    if (action === 'accept' || action === 'reject') openAction(regId, action, name);
    else if (action === 'cert') openCertModal(regId, name, workshop);
    else if (action === 'badge') openBadgeModal(regId, name);
  });

  function openAction(regId, action, name) {
    pendingAction = { regId: regId, action: action };
    var title = document.getElementById('action-modal-title');
    var info = document.getElementById('action-modal-info');
    var confirmBtn = document.getElementById('action-confirm');
    if (action === 'accept') {
      title.textContent = 'Başvuruyu Kabul Et';
      info.textContent = name + ' adlı kişinin başvurusu kabul edilecek.';
      confirmBtn.textContent = 'Kabul Et';
      confirmBtn.className = 'text-sm flex-1 py-2.5 px-4 rounded-lg bg-status-open text-bg-primary font-heading font-bold cursor-pointer';
    } else {
      title.textContent = 'Başvuruyu Reddet';
      info.textContent = name + ' adlı kişinin başvurusu reddedilecek.';
      confirmBtn.textContent = 'Reddet';
      confirmBtn.className = 'text-sm flex-1 py-2.5 px-4 rounded-lg bg-status-closed text-white font-heading font-bold cursor-pointer';
    }
    document.getElementById('action-message').value = '';
    var modal = document.getElementById('action-modal');
    modal.classList.remove('hidden'); modal.classList.add('flex');
  }

  function closeActionModal() { var m = document.getElementById('action-modal'); m.classList.add('hidden'); m.classList.remove('flex'); pendingAction = null; }
  document.getElementById('action-backdrop')?.addEventListener('click', closeActionModal);

  async function confirmAction() {
    if (!pendingAction) return;
    var key = document.getElementById('admin-key').value.trim();
    var message = document.getElementById('action-message').value.trim();
    var btn = document.getElementById('action-confirm');
    btn.textContent = 'Gönderiliyor...'; btn.disabled = true;
    try {
      var res = await fetch('/api/registrations', { method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ key: key, regId: pendingAction.regId, action: pendingAction.action, message: message }) });
      if (res.ok) {
        var reg = allRegistrations.find(function(r){return r.id === pendingAction.regId;});
        if (reg) { reg.status = pendingAction.action === 'accept' ? 'accepted' : 'rejected'; reg.reviewedAt = new Date().toISOString(); }
        closeActionModal(); updateStats(); renderCards();
      } else { alert('İşlem başarısız.'); }
    } catch(e) { alert('Bağlantı hatası.'); }
    finally { btn.disabled = false; }
  }

  function openCertModal(regId, name, workshop) {
    pendingCertRegId = regId;
    document.getElementById('cert-modal-info').textContent = name + ' — ' + workshop;
    document.getElementById('cert-type-select').value = 'participation';
    var m = document.getElementById('cert-modal'); m.classList.remove('hidden'); m.classList.add('flex');
  }
  function closeCertModal() { var m = document.getElementById('cert-modal'); m.classList.add('hidden'); m.classList.remove('flex'); pendingCertRegId = null; }
  async function confirmCert() {
    if (!pendingCertRegId) return;
    var key = document.getElementById('admin-key').value.trim();
    var certType = document.getElementById('cert-type-select').value;
    var btn = document.getElementById('cert-confirm'); btn.textContent = 'İşleniyor...'; btn.disabled = true;
    try {
      var res = await fetch('/api/registrations', { method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ key: key, regId: pendingCertRegId, action: 'issue-certificate', certType: certType }) });
      if (res.ok) { var result = await res.json(); var reg = allRegistrations.find(function(r){return r.id === pendingCertRegId;}); if (reg) reg.status = 'completed'; closeCertModal(); updateStats(); renderCards(); alert('Sertifika verildi: ' + (result.certId || 'OK')); }
      else { var err = await res.json().catch(function(){return {};}); alert('Hata: ' + (err.error || 'Başarısız')); }
    } catch(e) { alert('Bağlantı hatası.'); }
    finally { btn.textContent = 'Sertifika Ver'; btn.disabled = false; }
  }

  function openBadgeModal(regId, name) {
    pendingBadgeRegId = regId;
    document.getElementById('badge-modal-info').textContent = name;
    document.getElementById('badge-select').value = 'pioneer';
    var m = document.getElementById('badge-modal'); m.classList.remove('hidden'); m.classList.add('flex');
  }
  function closeBadgeModal() { var m = document.getElementById('badge-modal'); m.classList.add('hidden'); m.classList.remove('flex'); pendingBadgeRegId = null; }
  async function confirmBadge() {
    if (!pendingBadgeRegId) return;
    var key = document.getElementById('admin-key').value.trim();
    var badgeId = document.getElementById('badge-select').value;
    var btn = document.getElementById('badge-confirm'); btn.textContent = 'İşleniyor...'; btn.disabled = true;
    try {
      var res = await fetch('/api/registrations', { method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ key: key, regId: pendingBadgeRegId, action: 'award-badge', badgeId: badgeId }) });
      if (res.ok) { closeBadgeModal(); alert('Rozet verildi!'); }
      else { var err = await res.json().catch(function(){return {};}); alert('Hata: ' + (err.error || 'Başarısız')); }
    } catch(e) { alert('Bağlantı hatası.'); }
    finally { btn.textContent = 'Rozet Ver'; btn.disabled = false; }
  }

  function esc(str) { var d = document.createElement('div'); d.textContent = str || ''; return d.innerHTML; }
  function escAttr(str) { return (str||'').replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/'/g,'&#39;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
  function formatTS(ts) { if (!ts) return '-'; return new Date(ts).toLocaleDateString('tr-TR', { day:'numeric', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' }); }

  function exportCSV() {
    if (!allRegistrations.length) return;
    var h = ['Ad Soyad','E-posta','Üniversite','Bölüm','Atölye','Motivasyon','Durum','Tarih','Ülke'];
    var rows = allRegistrations.map(function(r){return [r.name,r.email,r.university,r.department,r.workshop,r.motivation||'',r.status||'pending',r.timestamp,r.country||''].map(function(v){return '"'+(v||'').replace(/"/g,'""')+'"';}).join(',');});
    var csv = [h.join(',')].concat(rows).join('\n');
    var blob = new Blob(['\uFEFF'+csv], { type: 'text/csv;charset=utf-8;' });
    var a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = 'legere-basvurular-'+new Date().toISOString().split('T')[0]+'.csv'; a.click();
  }

  function exportMembersCSV() {
    if (!allMembers.length) return;
    var h = ['Ad Soyad','E-posta','Üniversite','Bölüm','Kayıt Tarihi','Kayıt Kaynağı','Etkinlik Sayısı'];
    var rows = allMembers.map(function(m){return [m.name,m.email,m.university,m.department,m.joinDate,m.signupSource,m.registrationCount].map(function(v){return '"'+String(v||'').replace(/"/g,'""')+'"';}).join(',');});
    var csv = [h.join(',')].concat(rows).join('\n');
    var blob = new Blob(['\uFEFF'+csv], { type: 'text/csv;charset=utf-8;' });
    var a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = 'legere-uyeler-'+new Date().toISOString().split('T')[0]+'.csv'; a.click();
  }

  document.querySelector('[data-filter="all"]')?.style && (document.querySelector('[data-filter="all"]').style.opacity = '1');
</script>
