---
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/languages';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const privacyPath = lang === 'en' ? '/en/privacy/' : '/privacy/';
const termsPath = lang === 'en' ? '/en/terms/' : '/terms/';
---

<section id="trust" class="relative section-padding">
  <div class="max-w-4xl mx-auto">
    <div class="glass rounded-2xl p-8 md:p-10" data-animate>
      <div class="flex flex-col md:flex-row items-start gap-6">
        <!-- Shield icon -->
        <div class="flex-shrink-0">
          <div class="w-14 h-14 rounded-xl bg-gold-500/10 border border-gold-500/20 flex items-center justify-center">
            <svg class="w-7 h-7 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
            </svg>
          </div>
        </div>

        <div class="flex-1">
          <h3 class="text-lg font-heading font-bold text-text-primary mb-3">
            {t('trust.title')}
          </h3>
          <p class="text-text-secondary text-sm leading-relaxed mb-5">
            {t('trust.desc')}
          </p>
          <div class="flex flex-wrap items-center gap-4">
            <a href={privacyPath} class="inline-flex items-center gap-2 text-gold-500 hover:text-gold-300 transition-colors text-sm font-heading font-medium">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
              </svg>
              {t('trust.privacyLink')}
            </a>
            <span class="text-text-secondary/30">|</span>
            <a href={termsPath} class="text-text-secondary/70 hover:text-gold-500 transition-colors text-sm font-heading">
              {t('trust.termsLink')}
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
