---
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/languages';
import SectionHeading from '../components/SectionHeading.astro';
import publicationsData from '../data/publications.json';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const disciplineLabels: Record<string, Record<string, string>> = {
  criminology: { tr: 'Kriminoloji', en: 'Criminology' },
  sociology: { tr: 'Sosyoloji', en: 'Sociology' },
  philosophy: { tr: 'Felsefe', en: 'Philosophy' },
  'data-science': { tr: 'Veri Bilimi', en: 'Data Science' },
  law: { tr: 'Hukuk', en: 'Law' },
  psychology: { tr: 'Psikoloji', en: 'Psychology' },
  anthropology: { tr: 'Antropoloji', en: 'Anthropology' },
  'political-science': { tr: 'Siyaset Bilimi', en: 'Political Science' },
  communication: { tr: 'İletişim Bilimleri', en: 'Communication Sciences' },
  economics: { tr: 'Ekonomi', en: 'Economics' },
  ai: { tr: 'Yapay Zeka', en: 'Artificial Intelligence' },
  'international-relations': { tr: 'Uluslararası İlişkiler', en: 'International Relations' },
};
---

<section id="publications" class="relative section-padding">
  <div class="max-w-5xl mx-auto">
    <SectionHeading
      title={t('publications.title')}
      subtitle={t('publications.subtitle')}
    />

    {publicationsData.length > 0 ? (
      <div class="space-y-4" data-animate-stagger>
        {publicationsData.map((pub: any) => (
          <div class="glass p-6 hover:gold-glow transition-all duration-300 group">
            <div class="flex flex-col md:flex-row md:items-start gap-4">
              <div class="flex-1">
                <h3 class="text-lg font-heading font-bold text-text-primary group-hover:text-gold-500 transition-colors mb-2">
                  {pub.title[lang]}
                </h3>
                <p class="text-text-secondary text-sm mb-2">
                  {pub.authors.join(', ')}
                </p>
                <p class="text-text-secondary/70 text-sm leading-relaxed">
                  {pub.abstract[lang]}
                </p>
                <div class="flex flex-wrap gap-2 mt-3">
                  {pub.disciplines.map((d: string) => (
                    <span class="badge badge-discipline text-xs">
                      {disciplineLabels[d]?.[lang] ?? d}
                    </span>
                  ))}
                </div>
              </div>
              <div class="shrink-0 text-right">
                <span class="text-gold-500 font-mono text-sm">{pub.year}</span>
                {pub.url && (
                  <a
                    href={pub.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="block mt-2 text-sm text-gold-500/70 hover:text-gold-500 transition-colors"
                  >
                    PDF ↗
                  </a>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    ) : (
      <div class="glass p-16 text-center" data-animate>
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full glass-subtle mb-6">
          <svg class="w-8 h-8 text-gold-500/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
          </svg>
        </div>
        <p class="text-text-secondary text-lg mb-2">{t('publications.empty')}</p>
        <span class="badge badge-upcoming">{t('publications.comingSoon')}</span>
      </div>
    )}
  </div>
</section>
