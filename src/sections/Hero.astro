---
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/languages';
import OWLLogo from '../components/OWLLogo.astro';
import ParticleCanvas from '../components/ParticleCanvas.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <ParticleCanvas />

  <!-- Radial gradient overlay -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_transparent_0%,_#0A0A0F_70%)] z-[1]"></div>

  <!-- Content -->
  <div class="relative z-10 text-center px-4 max-w-4xl mx-auto">
    <!-- Badge -->
    <div class="hero-fade inline-flex items-center gap-2 px-4 py-2 rounded-full glass-subtle mb-8" style="animation: fadeInUp 0.8s ease-out 0.2s both;">
      <span class="w-2 h-2 rounded-full bg-gold-500 animate-pulse"></span>
      <span class="text-sm font-heading text-text-secondary tracking-wide">
        {t('hero.badge')}
      </span>
    </div>

    <!-- Logo -->
    <div class="hero-fade flex justify-center mb-6" style="animation: fadeInUp 0.8s ease-out 0.4s both;">
      <OWLLogo size="hero" animate />
    </div>

    <!-- Title -->
    <h1
      class="hero-fade text-4xl md:text-6xl lg:text-7xl font-heading font-bold tracking-tight mb-4"
      style="animation: fadeInUp 0.8s ease-out 0.6s both;"
    >
      <span class="text-gradient-gold">{t('hero.title')}</span>
    </h1>

    <!-- Subtitle -->
    <p
      class="hero-fade text-lg md:text-xl text-text-secondary font-heading mb-2"
      style="animation: fadeInUp 0.8s ease-out 0.8s both;"
    >
      {t('hero.subtitle')}
    </p>

    <!-- Legere meaning -->
    <p
      class="hero-fade text-sm text-gold-500/70 font-mono tracking-wider mb-10"
      style="animation: fadeInUp 0.8s ease-out 1s both;"
    >
      {t('hero.legere')}
    </p>

    <!-- CTAs -->
    <div class="hero-fade flex flex-col sm:flex-row items-center justify-center gap-4" style="animation: fadeInUp 0.8s ease-out 1.2s both;">
      <a href="#workshops" class="btn-gold">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
        </svg>
        {t('hero.cta')}
      </a>
      <a href="#about" class="btn-outline">
        {t('hero.cta2')}
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10" style="animation: fadeInUp 0.8s ease-out 1.6s both;">
    <a href="#about" class="flex flex-col items-center gap-2 text-text-secondary/50 hover:text-gold-500/70 transition-colors" aria-label="Scroll down">
      <svg class="w-5 h-5" style="animation: scrollDown 2s ease-in-out infinite;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </a>
  </div>
</section>
