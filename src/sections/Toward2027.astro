---
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/languages';
import SectionHeading from '../components/SectionHeading.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="relative section-padding">
  <div class="max-w-4xl mx-auto">
    <SectionHeading
      title={t('toward2027.title')}
      subtitle={t('toward2027.subtitle')}
    />

    <div class="glass p-8 md:p-10 relative overflow-hidden" data-animate>
      <!-- Ambient glow -->
      <div class="absolute top-0 right-0 w-48 h-48 bg-gold-500/[0.04] rounded-full blur-[80px]"></div>

      <p class="text-text-secondary leading-relaxed mb-8 relative z-[1]">
        {t('toward2027.desc')}
      </p>

      <div class="grid sm:grid-cols-2 gap-4 relative z-[1]">
        <!-- Ankara -->
        <div class="glass-subtle p-5 flex items-start gap-4 group hover:border-gold-500/25 transition-all duration-300">
          <div class="w-10 h-10 rounded-lg bg-gold-500/10 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
            </svg>
          </div>
          <div>
            <h4 class="font-heading font-bold text-text-primary text-sm mb-1">
              {t('toward2027.ankara')}
            </h4>
            <span class="badge badge-upcoming text-[10px]">{t('toward2027.planned')}</span>
          </div>
        </div>

        <!-- Istanbul -->
        <div class="glass-subtle p-5 flex items-start gap-4 group hover:border-gold-500/25 transition-all duration-300">
          <div class="w-10 h-10 rounded-lg bg-gold-500/10 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
            </svg>
          </div>
          <div>
            <h4 class="font-heading font-bold text-text-primary text-sm mb-1">
              {t('toward2027.istanbul')}
            </h4>
            <span class="badge badge-upcoming text-[10px]">{t('toward2027.planned')}</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
