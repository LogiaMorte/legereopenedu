---
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/languages';
import SectionHeading from '../components/SectionHeading.astro';
import EventTimeline from '../components/EventTimeline.astro';
import eventsData from '../data/events.json';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="calendar" class="relative section-padding bg-bg-secondary/50">
  <div class="max-w-5xl mx-auto">
    <SectionHeading
      title={t('calendar.title')}
      subtitle={t('calendar.subtitle')}
    />

    {eventsData.length > 0 ? (
      <EventTimeline lang={lang} events={eventsData} />
    ) : (
      <div class="glass p-12 text-center" data-animate>
        <p class="text-text-secondary text-lg">{t('calendar.empty')}</p>
      </div>
    )}

    <!-- Platform info notes -->
    <div class="mt-10 max-w-3xl mx-auto" data-animate>
      <div class="glass-subtle p-5 flex items-start gap-4">
        <div class="shrink-0 flex flex-col gap-2">
          <div class="w-10 h-10 rounded-xl bg-[#00897B]/10 border border-[#00897B]/25 flex items-center justify-center">
            <svg class="w-5 h-5 text-[#00897B]" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"/>
            </svg>
          </div>
        </div>
        <div>
          <h4 class="font-heading font-bold text-text-primary text-sm mb-1">
            <span class="text-[#00897B]">Google Meet</span> & <span class="text-[#7B83EB]">Microsoft Teams</span>
          </h4>
          <p class="text-text-secondary text-sm leading-relaxed">
            {t('calendar.meetNote')}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
