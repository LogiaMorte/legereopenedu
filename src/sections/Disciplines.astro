---
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/languages';
import SectionHeading from '../components/SectionHeading.astro';
import DisciplineCard from '../components/DisciplineCard.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const disciplines = [
  {
    icon: '<svg viewBox="0 0 48 48" class="w-10 h-10" fill="none" stroke="#D4A843" stroke-width="1.5"><path d="M24 6v36M12 18h24M8 12l8 6-8 6M40 12l-8 6 8 6"/><circle cx="24" cy="24" r="18" opacity="0.3"/></svg>',
    title: t('disciplines.criminology'),
    description: t('disciplines.criminology.desc'),
  },
  {
    icon: '<svg viewBox="0 0 48 48" class="w-10 h-10" fill="none" stroke="#D4A843" stroke-width="1.5"><circle cx="16" cy="20" r="6"/><circle cx="32" cy="20" r="6"/><circle cx="24" cy="34" r="6"/><line x1="20" y1="24" x2="28" y2="24" opacity="0.5"/><line x1="18" y1="26" x2="22" y2="30" opacity="0.5"/><line x1="30" y1="26" x2="26" y2="30" opacity="0.5"/></svg>',
    title: t('disciplines.sociology'),
    description: t('disciplines.sociology.desc'),
  },
  {
    icon: '<svg viewBox="0 0 48 48" class="w-10 h-10" fill="none" stroke="#D4A843" stroke-width="1.5"><path d="M16 38V22a8 8 0 0116 0v16"/><line x1="12" y1="38" x2="36" y2="38"/><circle cx="24" cy="14" r="4" opacity="0.5"/><path d="M20 28h8" opacity="0.5"/></svg>',
    title: t('disciplines.philosophy'),
    description: t('disciplines.philosophy.desc'),
  },
  {
    icon: '<svg viewBox="0 0 48 48" class="w-10 h-10" fill="none" stroke="#D4A843" stroke-width="1.5"><rect x="8" y="8" width="32" height="32" rx="4" opacity="0.3"/><polyline points="12,32 18,24 24,28 30,16 36,20"/><circle cx="18" cy="24" r="2" fill="#D4A843" opacity="0.5"/><circle cx="24" cy="28" r="2" fill="#D4A843" opacity="0.5"/><circle cx="30" cy="16" r="2" fill="#D4A843" opacity="0.5"/></svg>',
    title: t('disciplines.datascience'),
    description: t('disciplines.datascience.desc'),
  },
  {
    icon: '<svg viewBox="0 0 48 48" class="w-10 h-10" fill="none" stroke="#D4A843" stroke-width="1.5"><rect x="10" y="6" width="28" height="36" rx="2" opacity="0.3"/><line x1="16" y1="14" x2="32" y2="14"/><line x1="16" y1="20" x2="32" y2="20"/><line x1="16" y1="26" x2="28" y2="26"/><circle cx="24" cy="35" r="4" opacity="0.5"/><path d="M22 35l2 2 4-4" stroke-width="1.5"/></svg>',
    title: t('disciplines.law'),
    description: t('disciplines.law.desc'),
  },
  {
    icon: '<svg viewBox="0 0 48 48" class="w-10 h-10" fill="none" stroke="#D4A843" stroke-width="1.5"><circle cx="24" cy="16" r="10" opacity="0.3"/><path d="M14 16c0 5.5 4.5 10 10 10s10-4.5 10-10"/><path d="M20 22c0 0 2 4 4 4s4-4 4-4" opacity="0.5"/><path d="M18 38c0-4 2.7-7.3 6-8.5M30 38c0-4-2.7-7.3-6-8.5"/><circle cx="20" cy="14" r="1.5" fill="#D4A843" opacity="0.6"/><circle cx="28" cy="14" r="1.5" fill="#D4A843" opacity="0.6"/></svg>',
    title: t('disciplines.psychology'),
    description: t('disciplines.psychology.desc'),
  },
  {
    icon: '<svg viewBox="0 0 48 48" class="w-10 h-10" fill="none" stroke="#D4A843" stroke-width="1.5"><circle cx="24" cy="18" r="12" opacity="0.3"/><path d="M16 42c0-6 3.6-10 8-10s8 4 8 10"/><circle cx="24" cy="18" r="5"/><path d="M19 18c0-2.8 2.2-5 5-5" opacity="0.5"/></svg>',
    title: t('disciplines.anthropology'),
    description: t('disciplines.anthropology.desc'),
  },
  {
    icon: '<svg viewBox="0 0 48 48" class="w-10 h-10" fill="none" stroke="#D4A843" stroke-width="1.5"><rect x="10" y="10" width="28" height="28" rx="3" opacity="0.3"/><path d="M18 24h12M24 18v12"/><circle cx="18" cy="18" r="2" fill="#D4A843" opacity="0.4"/><circle cx="30" cy="18" r="2" fill="#D4A843" opacity="0.4"/><circle cx="18" cy="30" r="2" fill="#D4A843" opacity="0.4"/><circle cx="30" cy="30" r="2" fill="#D4A843" opacity="0.4"/></svg>',
    title: t('disciplines.polsci'),
    description: t('disciplines.polsci.desc'),
  },
  {
    icon: '<svg viewBox="0 0 48 48" class="w-10 h-10" fill="none" stroke="#D4A843" stroke-width="1.5"><circle cx="24" cy="24" r="16" opacity="0.3"/><path d="M12 24h24"/><path d="M24 12c-4 4-4 8 0 12s4 8 0 12" opacity="0.5"/><path d="M24 12c4 4 4 8 0 12s-4 8 0 12" opacity="0.5"/></svg>',
    title: t('disciplines.communication'),
    description: t('disciplines.communication.desc'),
  },
  {
    icon: '<svg viewBox="0 0 48 48" class="w-10 h-10" fill="none" stroke="#D4A843" stroke-width="1.5"><path d="M8 36l8-12 8 8 8-16 8 10" opacity="0.5"/><line x1="8" y1="40" x2="40" y2="40"/><line x1="8" y1="10" x2="8" y2="40"/><circle cx="16" cy="24" r="2" fill="#D4A843" opacity="0.4"/><circle cx="32" cy="16" r="2" fill="#D4A843" opacity="0.4"/></svg>',
    title: t('disciplines.economics'),
    description: t('disciplines.economics.desc'),
  },
  {
    icon: '<svg viewBox="0 0 48 48" class="w-10 h-10" fill="none" stroke="#D4A843" stroke-width="1.5"><rect x="12" y="8" width="24" height="32" rx="4" opacity="0.3"/><circle cx="24" cy="22" r="6"/><path d="M20 22h8M24 18v8" opacity="0.5"/><path d="M18 34h12" /><path d="M20 38h8" opacity="0.5"/></svg>',
    title: t('disciplines.ai'),
    description: t('disciplines.ai.desc'),
  },
  {
    icon: '<svg viewBox="0 0 48 48" class="w-10 h-10" fill="none" stroke="#D4A843" stroke-width="1.5"><circle cx="24" cy="24" r="18" opacity="0.2"/><ellipse cx="24" cy="24" rx="18" ry="8" opacity="0.3"/><ellipse cx="24" cy="24" rx="8" ry="18" opacity="0.3"/><circle cx="24" cy="24" r="3" fill="#D4A843" opacity="0.5"/></svg>',
    title: t('disciplines.intrelations'),
    description: t('disciplines.intrelations.desc'),
  },
];
---

<section id="disciplines" class="relative section-padding bg-bg-secondary/50">
  <div class="max-w-7xl mx-auto">
    <SectionHeading
      title={t('disciplines.title')}
      subtitle={t('disciplines.subtitle')}
    />

    <div class="grid md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5" data-animate-stagger>
      {disciplines.map((d) => (
        <DisciplineCard
          icon={d.icon}
          title={d.title}
          description={d.description}
        />
      ))}
    </div>
  </div>
</section>
