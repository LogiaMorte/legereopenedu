---
interface Props {
  title: string;
  description: string;
  icon: string;
}

const { title, description, icon } = Astro.props;
---

<div class="glass p-6 md:p-8 group hover:gold-glow transition-all duration-300 hover:-translate-y-1">
  <div class="text-4xl mb-4 opacity-80 group-hover:opacity-100 transition-opacity" set:html={icon} />
  <h3 class="text-xl font-heading font-bold text-text-primary mb-3 group-hover:text-gold-500 transition-colors">
    {title}
  </h3>
  <p class="text-text-secondary text-sm leading-relaxed">
    {description}
  </p>
</div>
