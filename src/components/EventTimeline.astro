---
import type { Lang } from '../i18n/languages';
import { useTranslations } from '../i18n/utils';

interface EventItem {
  title: Record<string, string>;
  date: string;
  endDate?: string;
  type: 'workshop' | 'seminar' | 'congress';
  platform?: 'meet' | 'classroom';
  description: Record<string, string>;
  location: Record<string, string>;
}

interface Props {
  lang: Lang;
  events: EventItem[];
}

const { lang, events } = Astro.props;
const t = useTranslations(lang);

const typeConfig = {
  workshop: { label: t('calendar.type.workshop'), class: 'badge-open' },
  seminar: { label: t('calendar.type.seminar'), class: 'badge-upcoming' },
  congress: { label: t('calendar.type.congress'), class: 'badge-discipline' },
};

const now = new Date();

const formatDate = (dateStr: string) => {
  const date = new Date(dateStr);
  return date.toLocaleDateString(lang === 'tr' ? 'tr-TR' : 'en-US', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
};
---

<div class="relative">
  <!-- Timeline line -->
  <div class="absolute left-4 md:left-1/2 md:-translate-x-px top-0 bottom-0 w-[2px] bg-gradient-to-b from-gold-500/40 via-gold-500/20 to-transparent"></div>

  <div class="space-y-8 md:space-y-12">
    {events.map((event, i) => {
      const isPast = new Date(event.date) < now;
      const isEven = i % 2 === 0;

      return (
        <div class={`relative flex items-start gap-6 md:gap-0 ${isPast ? 'opacity-50' : ''}`} data-animate>
          <!-- Timeline dot -->
          <div class={`absolute left-4 md:left-1/2 -translate-x-1/2 w-3 h-3 rounded-full border-2 z-10 mt-6 ${isPast ? 'border-text-secondary bg-bg-primary' : 'border-gold-500 bg-gold-500/30'}`}>
            {!isPast && <div class="absolute inset-0 rounded-full bg-gold-500/50 animate-ping"></div>}
          </div>

          <!-- Card -->
          <div class={`ml-10 md:ml-0 md:w-[calc(50%-2rem)] glass p-5 ${isEven ? 'md:mr-auto md:pr-8' : 'md:ml-auto md:pl-8'}`}>
            <div class="flex items-center gap-2 mb-2">
              <span class={`badge text-xs ${typeConfig[event.type].class}`}>
                {typeConfig[event.type].label}
              </span>
            </div>
            <h3 class="text-lg font-heading font-bold text-text-primary mb-1">
              {event.title[lang]}
            </h3>
            <p class="text-gold-500/80 text-sm font-mono mb-2">
              {formatDate(event.date)}
              {event.endDate && ` — ${formatDate(event.endDate)}`}
            </p>
            <p class="text-text-secondary text-sm mb-2">
              {event.description[lang]}
            </p>
            <div class="flex items-center gap-3 flex-wrap">
              <p class="text-text-secondary/60 text-xs">
                📍 {event.location[lang]}
              </p>
              {event.platform === 'meet' && (
                <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-md bg-[#00897B]/10 border border-[#00897B]/25">
                  <svg class="w-3 h-3 text-[#00897B]" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"/>
                  </svg>
                  <span class="text-[10px] font-mono text-[#00897B] tracking-wide">Google Meet</span>
                </span>
              )}
              {event.platform === 'classroom' && (
                <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-md bg-[#1e8e3e]/10 border border-[#1e8e3e]/25">
                  <svg class="w-3 h-3 text-[#1e8e3e]" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M21.6 6H2.4C1.08 6 0 7.08 0 8.4v7.2C0 16.92 1.08 18 2.4 18h19.2c1.32 0 2.4-1.08 2.4-2.4V8.4C24 7.08 22.92 6 21.6 6zM12 8.4c1.32 0 2.4 1.08 2.4 2.4s-1.08 2.4-2.4 2.4-2.4-1.08-2.4-2.4 1.08-2.4 2.4-2.4zm4.8 8.4H7.2v-.6c0-1.6 3.2-2.48 4.8-2.48s4.8.88 4.8 2.48v.6z"/>
                  </svg>
                  <span class="text-[10px] font-mono text-[#1e8e3e] tracking-wide">Classroom</span>
                </span>
              )}
            </div>
          </div>
        </div>
      );
    })}
  </div>
</div>
